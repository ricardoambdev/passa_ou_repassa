generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model UserAdmin {
  id           Int      @id @default(autoincrement())
  nome         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Question {
  id        Int      @id @default(autoincrement())
  pergunta  String
  resposta  String
  categoria String
  nivel     String
  pontos    Int
  createdAt DateTime @default(now())
}

model Challenge {
  id          Int      @id @default(autoincrement())
  nome        String
  descricao   String
  categoria   String
  tempo       String
  nivel       String
  instrucao   String
  createdAt   DateTime @default(now())
}

model Game {
  id        Int          @id @default(autoincrement())
  codigo    String       @unique
  status    String       @default("pending")
  createdAt DateTime     @default(now())
  teams     Team[]
  actions   GameAction[]
}

model Team {
  id     Int    @id @default(autoincrement())
  gameId Int
  nome   String
  cor    String
  pontos Int    @default(0)
  game   Game   @relation(fields: [gameId], references: [id])
}

model TeamConfig {
  id    Int    @id @default(autoincrement())
  nome  String
  cor   String
  ordem Int    @default(0)
}

model GameAction {
  id        Int      @id @default(autoincrement())
  gameId    Int
  tipo      String
  dados     String
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id])
}
